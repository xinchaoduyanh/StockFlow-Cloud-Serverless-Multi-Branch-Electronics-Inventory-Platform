DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stockflow_cloud?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="1d"
CORS_ORIGIN="http://localhost:3000"
SWAGGER_ENABLED="true"
PRISMA_CONNECT_ON_BOOT="false"

# AWS S3 Settings (Phase 2 Serverless Ingestion)
AWS_REGION="ap-southeast-1"
AWS_ACCESS_KEY_ID="replace-with-your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="replace-with-your-aws-secret-access-key"
AWS_S3_BUCKET="stockflow-imports-dev"
AWS_S3_ENDPOINT=""
